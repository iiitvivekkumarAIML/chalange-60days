## 5. Vectorised Operations (No Loops)

```python
a = np.array([1.0, 2.0, 3.0, 4.0])
b = np.array([0.5, 1.5, 2.5, 3.5])

# --- Element-wise arithmetic ---
print(a + b)     # [1.5 3.5 5.5 7.5]
print(a - b)     # [0.5 0.5 0.5 0.5]
print(a * b)     # [0.5 3.0 7.5 14.]
print(a / b)     # [2.  1.33 1.2  1.14]
print(a ** 2)    # [1.  4.  9.  16.]

# --- Universal functions (ufuncs) — element-wise, fast ---
np.sqrt(a)        # [1.  1.41 1.73 2.]
np.exp(a)         # [2.72 7.39 20.09 54.6]
np.log(a)         # [0.   0.69 1.10 1.39]
np.abs(a - 3)     # [2.  1.  0.  1.]
np.sin(a)         # element-wise sin
np.clip(a, 1.5, 3.5)  # [1.5 2.  3.  3.5]  — clamp values to range

# --- ML-specific vectorised patterns ---
# Sigmoid activation
def sigmoid(x):
    return 1 / (1 + np.exp(-x))

# Softmax (over last axis)
def softmax(x):
    e = np.exp(x - np.max(x))    # subtract max for numerical stability
    return e / e.sum()

# MSE loss (no loop)
y_true = np.array([1.0, 0.0, 1.0, 1.0, 0.0])
y_pred = np.array([0.9, 0.1, 0.8, 0.7, 0.2])
mse    = np.mean((y_true - y_pred) ** 2)
print(f"MSE: {mse:.4f}")          # MSE: 0.0300

# Binary Cross-Entropy loss
eps = 1e-8   # avoid log(0)
bce = -np.mean(y_true * np.log(y_pred + eps) + (1 - y_true) * np.log(1 - y_pred + eps))
print(f"BCE: {bce:.4f}")          # BCE: 0.1643
```

