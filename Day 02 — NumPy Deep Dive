## 9. Random Numbers for ML

```python
rng = np.random.default_rng(seed=42)   # ← always set a seed for reproducibility

# --- Distributions ---
uniform   = rng.uniform(0, 1, size=(3, 4))     # U[0, 1]
normal    = rng.normal(0, 1, size=(100, 10))   # N(0, 1) — standard normal
integers  = rng.integers(0, 10, size=(5,))     # random ints in [0, 10)
binomial  = rng.binomial(n=1, p=0.5, size=100) # coin flips

# --- Weight initialisation strategies (used in neural nets) ---
n_in, n_out = 784, 256

# Xavier / Glorot init — for sigmoid / tanh layers
limit = np.sqrt(6 / (n_in + n_out))
xavier_w = rng.uniform(-limit, limit, size=(n_in, n_out))

# He init — for ReLU layers
he_w = rng.normal(0, np.sqrt(2 / n_in), size=(n_in, n_out))

# --- Shuffling and sampling ---
data = np.arange(100)
rng.shuffle(data)                          # in-place shuffle (for train/test splits)

sample = rng.choice(data, size=10, replace=False)   # random sample without replacement

# --- Reproducibility pattern for ML projects ---
SEED = 42
np.random.seed(SEED)                 # legacy API
rng  = np.random.default_rng(SEED)  # modern API — preferred
```

